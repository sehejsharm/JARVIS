# ─────────────────────────────────────────────────────────────
#  JARVIS configuration — copy this file to ".env" and fill in.
#  Add ONE key below. Providers are tried in this order:
#  Gemini → Groq → Anthropic → OpenAI. The first valid key wins.
# ─────────────────────────────────────────────────────────────

# ── FREE, no credit card ─────────────────────────────────────
# Google Gemini (recommended free option): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash

# Groq (free, very fast): https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── PAID (require a credit card) ─────────────────────────────
# Anthropic: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Local server port (ignored on Vercel).
PORT=3000
